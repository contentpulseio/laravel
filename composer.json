{
    "name": "contentpulseio/laravel",
    "description": "Laravel integration for ContentPulse.io — webhook ingestion, local content storage, and rendering.",
    "type": "library",
    "license": "MIT",
    "keywords": ["contentpulse", "laravel", "cms", "content", "seo", "api-client"],
    "homepage": "https://github.com/contentpulseio/laravel",
    "authors": [
        {
            "name": "ContentPulse",
            "email": "dev@contentpulse.io"
        }
    ],
    "require": {
        "php": "^8.2",
        "contentpulse/contentpulse-php": "^0.1",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "ContentPulse\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ContentPulse\\Laravel\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/contentpulseio/contentpulse-php-sdk.git"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "ContentPulse\\Laravel\\ContentPulseServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": "phpunit"
    }
}
